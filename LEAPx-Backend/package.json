{
  "name": "my-nextjs-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --prefix \"{name}-{time}\" --timestamp-format \"YYYY-MM-dd HH:mm:ss\" -n \"NEXT,WORKERS\" -c \"blue,green\" \"next dev\" \"npm run dev:workers\"",
    "dev:simple": "concurrently \"next dev\" \"dotenv -e .env.local -- tsx --watch src/workers/index.ts\"",
    "dev:workers": "dotenv -e .env.local -- tsx --watch src/workers/index.ts",
    "build": "next build",
    "start": "concurrently --prefix \"{name}-{time}\" --timestamp-format \"YYYY-MM-dd HH:mm:ss\" -n \"NEXT,WORKERS\" -c \"blue,green\" \"next start\" \"npm run start:workers\"",
    "start:simple": "next start",
    "start:workers": "dotenv -e .env.local -- tsx src/workers/index.ts",
    "lint": "eslint"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "axios": "^1.11.0",
    "bullmq": "^5.66.4",
    "cloudinary": "^2.8.0",
    "concurrently": "^9.2.1",
    "cron": "^4.4.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "firebase-admin": "^13.6.0",
    "ioredis": "^5.9.0",
    "jose": "^6.0.11",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.5.7",
    "next-cloudinary": "^6.16.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "styled-components": "^6.1.19",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "postcss": "^8.4.47",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
