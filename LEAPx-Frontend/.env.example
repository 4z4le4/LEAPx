# LEAP frontend environment example
# Copy this file to .env and replace placeholder values.

# CMU Entra ID
VITE_CMU_ENTRAID_CLIENT_ID=your-client-id
VITE_CMU_ENTRAID_REDIRECT_URL=http://localhost:5173/cmuEntraIDCallback
VITE_CMU_ENTRAID_SCOPE=api://cmu/Mis.Account.Read.Me.Basicinfo offline_access
VITE_CMU_ENTRAID_LOGOUT_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/logout?post_logout_redirect_uri=http://localhost:5173

# Backend
VITE_LEAP_BACKEND_URL=http://localhost:3000
VITE_LEAP_BACKEND_CODE=your-backend-code

# Optional legacy fallback URLs (used in some pages)
VITE_BACKEND_URL=http://localhost:3000
VITE_SERVER_URL=http://localhost:3000

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Firebase Cloud Messaging
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_VAPID_KEY=your-firebase-vapid-key
